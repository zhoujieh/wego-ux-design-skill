{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wego Design Tokens",
  "type": "object",
  "required": ["name", "version", "tokens"],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "fontFaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["family", "source", "weight"],
        "properties": {
          "family": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "weight": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      }
    },
    "tokens": {
      "type": "object",
      "patternProperties": {
        "^wg\\.[A-Za-z0-9]+(?:\\.[A-Za-z0-9]+)+$": {
          "type": "object",
          "required": ["value", "type", "category", "description"],
          "properties": {
            "value": {
              "type": ["string", "number"]
            },
            "type": {
              "enum": [
                "color",
                "fontFamily",
                "dimension",
                "shadow",
                "duration",
                "cubicBezier",
                "number",
                "string"
              ]
            },
            "category": {
              "enum": [
                "color",
                "typography",
                "spacing",
                "radius",
                "size",
                "layout",
                "elevation",
                "stroke",
                "blur",
                "motion",
                "z-index",
                "copywriting"
              ]
            },
            "description": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
