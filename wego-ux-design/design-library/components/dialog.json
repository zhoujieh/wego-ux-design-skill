{
  "schemaVersion": 2,
  "slug": "dialog",
  "name": "对话框",
  "category": "feedback",
  "variantDimensions": {
    "variant": {
      "description": "对话框内容类型",
      "values": ["text", "title", "status", "custom"],
      "default": "title"
    },
    "buttons": {
      "description": "按钮排列方式",
      "values": ["single", "dual"],
      "default": "dual"
    },
    "tone": {
      "description": "对话框语气/危险性",
      "values": ["default", "danger"],
      "default": "default"
    },
    "state": {
      "description": "显示状态",
      "values": ["open", "closed"],
      "default": "open"
    }
  },
  "tokensConsumed": [
    "wg-spacing-0", "wg-spacing-2", "wg-spacing-4", "wg-spacing-8", "wg-spacing-12", "wg-spacing-24", "wg-spacing-32",
    "wg-size-24", "wg-size-48",
    "wg-radius-lg", "wg-radius-sm",
    "wg-font-size-16", "wg-font-size-18",
    "wg-font-lineheight-16", "wg-font-lineheight-18",
    "wg-font-weight-regular", "wg-font-weight-medium", "wg-font-weight-semibold",
    "wg-font-family-text",
    "wg-component-dialog-width", "wg-component-dialog-padding-block", "wg-component-dialog-padding-inline", "wg-component-dialog-title-only-padding-block", "wg-component-dialog-button-height", "wg-component-dialog-closed-scale",
    "wg-color-bg-surface",
    "wg-color-overlay-light",
    "wg-color-text-primary", "wg-color-text-disabled",
    "wg-color-action-link-default",
    "wg-color-action-danger-default",
    "wg-color-status-success-default", "wg-color-status-danger-default", "wg-color-status-warning-default",
    "wg-color-divider-default",
    "wg-color-state-focus", "wg-color-state-hover", "wg-color-state-pressed",
    "wg-shadow-xl",
    "wg-stroke-width-none", "wg-stroke-width-hairline", "wg-stroke-width-strong",
    "wg-stroke-style-none", "wg-stroke-style-solid",
    "wg-motion-duration-fast", "wg-motion-duration-normal",
    "wg-motion-ease-standard", "wg-motion-ease-emphasized",
    "wg-zindex-modal"
  ],
  "domAnatomy": {
    "root": ".wg-dialog-overlay",
    "stateAttributes": ["data-state='open'", "data-state='closed'"],
    "modifiers": [],
    "children": {
      "dialog": {
        "root": ".wg-dialog",
        "modifiers": [
          ".wg-dialog--text",
          ".wg-dialog--title",
          ".wg-dialog--status",
          ".wg-dialog--custom"
        ]
      },
      "content": ".wg-dialog__content",
      "header": ".wg-dialog__header",
      "title": ".wg-dialog__title",
      "icon": ".wg-dialog__icon",
      "description": ".wg-dialog__description",
      "contentLink": ".wg-link.wg-link--inline",
      "custom": ".wg-dialog__custom",
      "action": ".wg-dialog__action",
      "buttons": ".wg-dialog__buttons",
      "button": ".wg-dialog__button"
    }
  },
  "usageHints": [
    "dialog 默认宽度为 300px，mask 默认覆盖 100% 宽高，遮罩视觉为 30% 不透明度，mask 自身不设置 padding",
    "wg-dialog__content 默认 padding 为 24px 20px；仅标题的 title 变体 padding 为 32px 20px",
    "wg-dialog__content 内容间距 gap 为 12px；仅标题场景不设置 min-block-size，内容区高度完全自适应",
    "每个内容类型必须在 .wg-dialog 上添加对应修饰类：.wg-dialog--text / --title / --status / --custom",
    "status 变体：标题左侧显示 24x24 状态图标，success 使用 icon-gou，danger/error 使用 icon-cha-cu，正文可选",
    "正文链接必须复用 link 组件，使用 .wg-link.wg-link--inline 及其 .wg-link__surface / .wg-link__label 结构",
    "custom 变体：标题 + 描述 + 自定义内容区域，.wg-dialog__custom 自身不带 padding 或 margin 间距",
    "dual 按钮为左右均分布局，中间用分割线隔开；single 仅保留右侧确认按钮",
    "wg-dialog__button 高度固定为 48px，取消按钮和主按钮字重都使用 medium",
    "默认确认按钮使用蓝色 link action token；danger 确认按钮需加 .wg-dialog__button--danger；hover/pressed 只改变按钮背景色，文字颜色不做状态变化",
    "通过 data-state='open'/'closed' 控制显示，closed 时 pointer-events: none",
    "打开动效：mask opacity 从 0 过渡到 30% 遮罩视觉，dialog 从 0.9 scale 过渡到 1",
    "confirm 按钮用 .wg-dialog__button--confirm，dismiss 用 .wg-dialog__button--dismiss",
    "disabled 状态使用 disabled 属性，hover/pressed/focus-visible 状态由 CSS 自动处理"
  ],
  "doNotInvent": [
    "不要自创对话框尺寸，固定使用默认 300px 宽度",
    "不要添加第三个按钮",
    "不要修改 mask 的 100% 宽高覆盖和 30% 遮罩视觉",
    "不要把双按钮改成带间距布局，必须使用中间分割线",
    "不要在 hover/pressed 时改变按钮文字颜色，只允许改变按钮背景色",
    "不要把 status 图标放到标题上方，必须和标题同行左置",
    "不要为正文链接自创 .wg-dialog__link，必须复用 link 组件",
    "不要给 .wg-dialog__custom 添加 padding 或 margin",
    "不要用 display: none 控制打开/关闭，必须使用 data-state + transform/opacity 过渡",
    "不要省略 .wg-dialog--text / --title / --status / --custom 修饰类"
  ],
  "provenance": {
    "preview": "preview/component-dialog.html",
    "css": { "file": "components.css", "marker": "Dialog" }
  },
  "knownIssues": []
}
