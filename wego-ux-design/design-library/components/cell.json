{
  "schemaVersion": 2,
  "slug": "cell",
  "name": "单元格",
  "category": "display",
  "variantDimensions": {
    "lineCount": {
      "description": "文本行数密度",
      "values": ["single", "double"],
      "default": "single"
    },
    "avatar": {
      "description": "头像槽位尺寸",
      "values": ["none", "sm", "lg"],
      "default": "none"
    },
    "select": {
      "description": "是否包含左侧选择区",
      "values": ["false", "true"],
      "default": "false"
    },
    "indent": {
      "description": "是否包含左侧缩进/层级标记区",
      "values": ["false", "true"],
      "default": "false"
    },
    "rightAction": {
      "description": "右侧动作区类型",
      "values": ["none", "jump", "text", "link", "switch", "button", "custom"],
      "default": "none"
    },
    "divider": {
      "description": "底部分割线策略",
      "values": ["full", "inset", "none"],
      "default": "none"
    },
    "tone": {
      "description": "背景语义",
      "values": ["surface", "grey"],
      "default": "surface"
    },
    "state": {
      "description": "交互状态",
      "values": ["default", "pressed", "disabled"],
      "default": "default"
    }
  },
  "tokensConsumed": [
