  },
  "usageHints": [
    "Cell 根结构始终遵循 16 左边距 + 可选左槽位 + 主内容区的布局，不要手写新的栅格",
    "左侧选择区直接复用 checkbox / radio，右侧开关直接复用 switch，右侧按钮直接复用 compact button",
    "double 模式用于带副标题的两行文本；avatar-lg + single 的最小高度是 64，double 是 76",
    "divider-inset 的起点会自动扣除左侧缩进、选择区和头像区宽度，不要再额外写死 inset 值",
    "grey 背景用于灰底列表或分组块中的 cell"
  ],
  "doNotInvent": [
    "不要把 Cell 改成固定两列栅格布局",
    "不要在 select / indent / avatar 槽位里塞入未注册的新控件",
    "不要手写分割线起点，必须依赖内置 CSS 变量累加逻辑",
    "不要给 disabled 态保留高对比箭头或操作文字",
    "不要绕过基础组件，重复实现 checkbox / radio / switch / button"
  ],
  "knownIssues": [
    "active 态当前同时使用 wg-color-state-pressed 与 wg-color-surface-active，两套表面态 token 语义后续可再统一"
  ],
  "provenance": {
    "preview": "preview/component-cell.html",
    "css": { "file": "components.css", "marker": "Cell" }
  }
}
