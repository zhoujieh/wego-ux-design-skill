  "domAnatomy": {
    "root": ".wg-cell",
    "modifiers": [
      ".wg-cell--double",
      ".wg-cell--avatar-sm",
      ".wg-cell--avatar-lg",
      ".wg-cell--select",
      ".wg-cell--indent",
      ".wg-cell--divider-full",
      ".wg-cell--divider-inset",
      ".wg-cell--grey",
      ".wg-cell--disabled"
    ],
    "children": {
      "indent": ".wg-cell__indent",
      "indentMark": ".wg-cell__indent-mark",
      "select": ".wg-cell__select",
      "controlIcon": ".wg-cell__control-icon",
      "avatarSlot": {
        "root": ".wg-cell__avatar-slot",
        "modifiers": [
          ".wg-cell__avatar-slot--sm",
          ".wg-cell__avatar-slot--lg"
        ]
      },
      "avatar": ".wg-cell__avatar",
      "main": ".wg-cell__main",
      "text": ".wg-cell__text",
      "titleRow": ".wg-cell__title-row",
      "title": ".wg-cell__title",
      "subtitle": ".wg-cell__subtitle",
      "subtitleLink": ".wg-cell__subtitle-link",
      "action": {
        "root": ".wg-cell__action",
        "modifiers": [
          ".wg-cell__action--switch",
          ".wg-cell__action--button",
          ".wg-cell__action--link"
        ]
      },
      "actionText": ".wg-cell__action-text",
      "actionTextLink": ".wg-cell__action-text--link",
      "arrow": ".wg-cell__arrow"
